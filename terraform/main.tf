terraform {
  required_version = ">= 1.3.0"

  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = var.aws_region

  default_tags {
    tags = {
      Project     = "sagemaker-autopilot-demo"
      ManagedBy   = "terraform"
      Owner       = var.owner_tag
    }
  }
}
